  "tokenColorCustomizations": {
    "comments": "#8cb7a9",
    "textMateRules": [
      {
        "scope": [
          "keyword",
          "storage.type",
          "storage.modifier"
        ],
        "settings": {
          "foreground": "#35d6a0"
        }
      },
      {
        "scope": [
          "string",
          "string.quoted",
          "string.template"
        ],
        "settings": {
          "foreground": "#94f1cd"
        }
      },
      {
        "scope": [
          "constant.numeric",
          "constant.language",
          "support.constant"
        ],
        "settings": {
          "foreground": "#ffd479"
        }
      },
      {
        "scope": [
          "entity.name.function",
          "support.function",
          "meta.function-call"
        ],
        "settings": {
          "foreground": "#d8f7ea"
        }
      },
      {
        "scope": [
          "variable",
          "meta.definition.variable",
          "entity.name.type"
        ],
        "settings": {
          "foreground": "#a7d3c2"
        }
      },
      {
        "scope": [
          "invalid",
          "invalid.illegal"
        ],
        "settings": {
          "foreground": "#ff5f56"
        }
      }
    ]
  }
}
