#!/bin/bash

# Returns a battery icon + percentage for hyprlock.
# Outputs nothing if no battery is present.

export PATH="$HOME/.local/share/leenium/bin:$PATH"

leenium-battery-present || exit 0

bat_path=$(upower -e 2>/dev/null | grep BAT | head -1)
[[ -z $bat_path ]] && exit 0

bat_info=$(upower -i "$bat_path" 2>/dev/null)
percentage=$(echo "$bat_info" | awk '/percentage/ { print int($2); exit }')
state=$(echo "$bat_info" | awk '/state/ { print $2; exit }')

[[ -z $percentage ]] && exit 0

if [[ $state == "charging" || $state == "fully-charged" ]]; then
  icon="㬚ｄ"
elif (( percentage > 80 )); then icon="㬚∋"
elif (( percentage > 60 )); then icon="㬚℧"
elif (( percentage > 40 )); then icon="㬚∪"
elif (( percentage > 20 )); then icon="㬚⊇"
else icon="㬚⊆"
fi

echo "$icon  $percentage%"
