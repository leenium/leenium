  case $(menu "Install" "пҶ¶  Steam\nп„ӣ  Lutris\nу°ў№  NVIDIA GeForce NOW\nп„ӣ  RetroArch [AUR]\nу°Қі  Minecraft [AUR]\nу°–ә  Xbox Controller [AUR]") in
