show_install_font_menu() {
  case $(menu "Install" "оҷҷ  Cascadia Mono\nоҷҷ  Meslo LG Mono\nоҷҷ  Fira Code\nоҷҷ  Victor Code\nоҷҷ  Bistream Vera Mono\nоҷҷ  Iosevka" "--width 350") in
