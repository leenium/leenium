  case $(menu "Install" "  Tailscale\n󱇱  NordVPN [AUR]\n  Telegram\n󰭹  Signal\n  Discord\n  Chromium Account\n󰏖  ONCE [AUR]") in
  *Tailscale*) present_terminal leenium-install-tailscale ;;
  *NordVPN*) present_terminal leenium-install-nordvpn ;;
  # *Bitwarden*) install_and_launch "Bitwarden" "bitwarden bitwarden-cli" "bitwarden" ;;
  # *Thunderbird*) install "Thunderbird" "thunderbird" ;;
  *Telegram*) install "Telegram" "telegram-desktop" ;;
  *Signal*) install "Signal" "signal-desktop" ;;
  *Discord*) install "Discord" "discord" ;;
  *Chromium*) present_terminal leenium-install-chromium-google-account ;;
  *ONCE*) present_terminal leenium-install-once ;;
  *) show_install_menu ;;
  esac
}

show_install_editor_menu() {
  case $(menu "Install" "  VSCode\n  Cursor\n  Zed\n  Helix\n  Emacs") in
  *VSCode*) present_terminal leenium-install-vscode ;;
  *Cursor*) aur_install_and_launch "Cursor" "cursor-bin" "cursor" ;;
  *Zed*) install_and_launch "Zed" "zed" "dev.zed.Zed" ;;
  *Helix*) install "Helix" "helix" ;;
  *Emacs*) install "Emacs" "emacs-wayland" && systemctl --user enable --now emacs.service ;;
  *) show_install_menu ;;
  esac
}

