show_remove_menu() {
  case $(menu "Remove" "󰣇  Packages\n  Web App\n  TUI\n  Service\n󰏓  Preinstalls\n󰸌  Theme\n󰵮  Development\n  Editor\n  Terminal\n󱚤  AI\n󰍲  Windows\n󰈷  Fingerprint\n  Fido2") in
  *Packages*) terminal leenium-pkg-remove ;;
  *Web*) present_terminal leenium-webapp-remove ;;
  *TUI*) present_terminal leenium-tui-remove ;;
  *Service*) show_remove_service_menu ;;
  *Preinstalls*) present_terminal leenium-remove-preinstalls ;;
  *Theme*) present_terminal leenium-theme-remove ;;
  *Development*) show_remove_development_menu ;;
  *Editor*) show_remove_editor_menu ;;
  *Terminal*) show_remove_terminal_menu ;;
  *AI*) show_remove_ai_menu ;;
  *Windows*) present_terminal "leenium-windows-vm remove" ;;
  *Fingerprint*) present_terminal "leenium-setup-fingerprint --remove" ;;
  *Fido2*) present_terminal "leenium-setup-fido2 --remove" ;;
  *) show_main_menu ;;
  esac
}

show_remove_service_menu() {
  case $(menu "Remove" "  Tailscale\n󱇱  NordVPN [AUR]\n  Telegram\n󰭹  Signal\n  Discord\n  Chromium Account\n󰏖  ONCE [AUR]") in
  *Tailscale*) present_terminal "leenium-pkg-drop tailscale && leenium-webapp-remove Tailscale || true" ;;
  *NordVPN*) present_terminal "leenium-pkg-drop nordvpn-bin" ;;
  *Telegram*) present_terminal "leenium-pkg-drop telegram-desktop" ;;
  *Signal*) present_terminal "leenium-pkg-drop signal-desktop" ;;
  *Discord*) present_terminal "leenium-pkg-drop discord" ;;
  *Chromium*) present_terminal "if [[ -f ~/.config/chromium-flags.conf ]]; then sed -i '/--oauth2-client-id=77185425430\\.apps\\.googleusercontent\\.com/d; /--oauth2-client-secret=OTJgUOQcT7lO7GsGZq2G4IlT/d' ~/.config/chromium-flags.conf; fi" ;;
  *ONCE*) present_terminal "leenium-pkg-drop once-bin" ;;
  *) show_remove_menu ;;
  esac
}

