show_about() {
  leenium-launch-about
}

show_system_menu() {
  local options="󱄄  Screensaver\n  Lock"
  ! leenium-toggle-enabled suspend-off && options="$options\n󰒲  Suspend"
  leenium-hibernation-available && options="$options\n󰤁  Hibernate"
  options="$options\n󰍃  Logout\n󰜉  Restart\n󰐥  Shutdown"

  case $(menu "System" "$options") in
  *Screensaver*) leenium-launch-screensaver force ;;
  *Lock*) leenium-lock-screen ;;
  *Suspend*) systemctl suspend ;;
  *Hibernate*) systemctl hibernate ;;
  *Logout*) leenium-system-logout ;;
  *Restart*) leenium-system-reboot ;;
  *Shutdown*) leenium-system-shutdown ;;
  *) back_to show_main_menu ;;
  esac
}

show_main_menu() {
  # go_to_menu "$(menu "Go" "󰀻  Apps\n󰧑  Learn\n󱓞  Trigger\n  Containers\n  Style\n  Settings\n󰘦  Config\n󰏗  Packages\n  Update\n  About\n  System")"
  go_to_menu "$(menu "Go" "󰀻  Apps\n󰧑  Learn\n󱓞  Actions\n  Appearance\n󱧘  Install\n󱧗  Remove\n  Settings\n  Update\n  About\n  System")"
}

go_to_menu() {
  case "${1,,}" in
  *apps*) walker -p "Launch…" ;;
  *learn*) show_learn_menu ;;
  *action*) show_action_menu ;;
  # *containers*) show_containers_menu ;;
  *appearance*) show_appearance_menu ;;
  *install*) show_install_menu ;;
  *remove*) show_remove_menu ;;
  *settings*) show_settings_menu ;;
  *update*) show_update_menu ;;
  *about*) show_about ;;
  *system*) show_system_menu ;;

  *share*) show_share_menu ;;
  *toggle*) show_toggle_menu ;;
  *background*) show_background_menu ;;
  *capture*) show_capture_menu ;;
  *theme*) show_theme_menu ;;
  *screenrecord*) show_screenrecord_menu ;;
  *power*) show_setup_power_menu ;;
  esac
}

# Allow user extensions and overrides
USER_EXTENSIONS="$HOME/.config/leenium/extensions/menu.sh"
[[ -f $USER_EXTENSIONS ]] && source "$USER_EXTENSIONS"

toggle_existing_menu

if [[ -n $1 ]]; then
  BACK_TO_EXIT=true
  go_to_menu "$1"
else
  show_main_menu
fi
