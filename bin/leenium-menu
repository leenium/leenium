  *Victor*) install_font "Victor Code" "ttf-victor-mono-nerd" "VictorMono Nerd Font" ;;
  *Bistream*) install_font "Bistream Vera Code" "ttf-bitstream-vera-mono-nerd" "BitstromWera Nerd Font" ;;
  *Iosevka*) install_font "Iosevka" "ttf-iosevka-nerd" "Iosevka Nerd Font Mono" ;;
  *) show_install_menu ;;
  esac
}

show_install_development_menu() {
  case $(menu "Install" "оқЁ  Clojure\nпҲҹ  Docker DB\nоҳӯ  Elixir\nоҳ§  Go\nоңё  Java\nоһҒ  JavaScript\nоқҝ  .NET\nоЎҺ  OCaml\nоңҪ  PHP\nоңј  Python\nу°«Ҹ  Ruby on Rails\nоһЁ  Rust\nоң·  Scala\nоЈҜ  Zig") in
  *Clojure*) present_terminal "leenium-install-dev-env clojure" ;;
  *Docker*) present_terminal leenium-install-docker-dbs ;;
  *Elixir*) show_install_elixir_menu ;;
  *Go*) present_terminal "leenium-install-dev-env go" ;;
  *Java*) present_terminal "leenium-install-dev-env java" ;;
  *JavaScript*) show_install_javascript_menu ;;
  *NET*) present_terminal "leenium-install-dev-env dotnet" ;;
  *OCaml*) present_terminal "leenium-install-dev-env ocaml" ;;
  *PHP*) show_install_php_menu ;;
