#!/bin/bash

# Launch the Leenium Menu or takes a parameter to jump straight to a submenu.

export PATH="$HOME/.local/share/leenium/bin:$PATH"

# Set to true when going directly to a submenu, so we can exit directly
BACK_TO_EXIT=false
MENU_BACK="__menu_back__"
MENU_EXIT="__menu_exit__"

back_to() {
  local parent_menu="$1"

  if [[ $BACK_TO_EXIT == "true" ]]; then
    exit 0
  elif [[ -n $parent_menu ]]; then
    "$parent_menu"
  else
    show_main_menu
  fi
}

toggle_existing_menu() {
  if pgrep -f "walker.*--dmenu" >/dev/null; then
    walker --close >/dev/null 2>&1
    exit 0
  fi
}

menu_with_back() {
  local options="$1"

  if [[ -n $options ]]; then
    printf '%s\nу°Ң‘  Back' "$options"
  else
    printf 'у°Ң‘  Back'
  fi
}

menu_with_exit() {
  local options="$1"

  if [[ -n $options ]]; then
    printf '%s\nу°ҲҶ  Exit' "$options"
  else
    printf 'у°ҲҶ  Exit'
  fi
}

menu() {
  local prompt="$1"
  local options="$2"
  local extra="$3"
  local preselect="$4"
  local options_to_show="$options"
  local selection=""

  read -r -a args <<<"$extra"

  if [[ $BACK_TO_EXIT == "true" ]]; then
    options_to_show="$options"
  elif [[ $prompt == "Go" ]]; then
    options_to_show=$(menu_with_exit "$options")
  else
    options_to_show=$(menu_with_back "$options")
  fi

  if [[ -n $preselect ]]; then
    local index
    index=$(echo -e "$options_to_show" | grep -nxF "$preselect" | cut -d: -f1)
    if [[ -n $index ]]; then
      args+=("-c" "$index")
    fi
  fi

  selection=$(echo -e "$options_to_show" | leenium-launch-walker --dmenu --width 295 --minheight 1 --maxheight 630 -p "$promptвҖҰ" "${args[@]}" 2>/dev/null)

  case $selection in
  "у°Ң‘  Back") echo "$MENU_BACK" ;;
  "у°ҲҶ  Exit") echo "$MENU_EXIT" ;;
  *) echo "$selection" ;;
  esac
}

terminal() {
  xdg-terminal-exec --app-id=org.leenium.terminal "$@"
}

present_terminal() {
  leenium-launch-floating-terminal-with-presentation $1
}

run_container_fn() {
  local cmd="$1"
  present_terminal "source \"$HOME/.local/share/leenium/default/bash/fns/containers\" && $cmd"
}

run_network_cmd() {
  local cmd="$1"
  present_terminal "$cmd"
}

open_in_editor() {
  notify-send -u low "Editing config file" "$1"
  leenium-launch-editor "$1"
}

install() {
  present_terminal "echo 'Installing $1...'; leenium-pkg-add $2"
}

install_and_launch() {
  present_terminal "echo 'Installing $1...'; leenium-pkg-add $2 && setsid gtk-launch $3"
}

install_font() {
  present_terminal "echo 'Installing $1...'; leenium-pkg-add $2 && sleep 2 && leenium-font-set '$3'"
}

install_terminal() {
  present_terminal "leenium-install-terminal $1"
}

aur_install() {
  present_terminal "echo 'Installing $1 from AUR...'; leenium-pkg-aur-add $2"
}

aur_install_and_launch() {
  present_terminal "echo 'Installing $1 from AUR...'; leenium-pkg-aur-add $2 && setsid gtk-launch $3"
}

show_learn_menu() {
  case $(menu "Learn" "п„ң  Keybindings\nпҗ…  Leenium\nпҚҷ  Hyprland\nу°ЈҮ  Arch\nоҡ®  Neovim\nуұҶғ  Bash") in
  "$MENU_BACK") show_main_menu ;;
  "$MENU_EXIT") exit 0 ;;
  *Keybindings*) leenium-menu-keybindings ;;
  *Leenium*) leenium-launch-webapp "https://leenium.drunkleen.com" ;;
  *Hyprland*) leenium-launch-webapp "https://wiki.hypr.land/" ;;
  *Arch*) leenium-launch-webapp "https://wiki.archlinux.org/title/Main_page" ;;
  *Bash*) leenium-launch-webapp "https://devhints.io/bash" ;;
  *Neovim*) leenium-launch-webapp "https://nvchad.com/docs/features#nvcheatsheet" ;;
  *) show_main_menu ;;
  esac
}

show_action_menu() {
  case $(menu "Actions" "пҖ°  Capture\nп”Һ  Share\nу°”Һ  Toggle") in
  "$MENU_BACK") show_main_menu ;;
  "$MENU_EXIT") exit 0 ;;
  *Capture*) show_capture_menu ;;
  *Share*) show_share_menu ;;
  *Toggle*) show_toggle_menu ;;
  *) show_main_menu ;;
  esac
}

show_network_tailscale_menu() {
  case $(menu "Tailscale" "у°җҠ  Up\nу°“ӣ  Down\nу°Ӣј  Status\nу°һҒ  Nodes") in
  "$MENU_BACK") show_connectivity_menu ;;
  "$MENU_EXIT") exit 0 ;;
  *Up*) run_network_cmd "sudo systemctl start tailscaled && sudo tailscale up --accept-routes && tailscale status" ;;
  *Down*) run_network_cmd "sudo tailscale down && tailscale status || true" ;;
  *Status*) run_network_cmd "tailscale status; printf '\n'; tailscale ip || true" ;;
  *Nodes*) run_network_cmd "tailscale status" ;;
  *) show_connectivity_menu ;;
  esac
}

show_connectivity_menu() {
  local options=""

  if command -v tailscale >/dev/null 2>&1; then
    options="у°Ҡ   Tailscale\n"
  fi

  options="${options}пҮ«  Wi-Fi\nу°ӮҜ  Bluetooth"

  case $(menu "Connectivity" "$options") in
  "$MENU_BACK") show_settings_menu ;;
  "$MENU_EXIT") exit 0 ;;
  *Tailscale*) show_network_tailscale_menu ;;
  *Wi-Fi*) leenium-launch-wifi ;;
  *Bluetooth*) leenium-launch-bluetooth ;;
  *) show_settings_menu ;;
  esac
}

show_capture_menu() {
  case $(menu "Capture" "пҖ°  Screenshot\nпҖҪ  Screenrecord\nу°ғү  Color") in
  "$MENU_BACK") back_to show_action_menu ;;
  "$MENU_EXIT") exit 0 ;;
  *Screenshot*) leenium-cmd-screenshot ;;
  *Screenrecord*) show_screenrecord_menu ;;
  *Color*) pkill hyprpicker || hyprpicker -a ;;
  *) back_to show_action_menu ;;
  esac
}

get_webcam_list() {
  v4l2-ctl --list-devices 2>/dev/null | while IFS= read -r line; do
    if [[ $line != $'\t'* && -n $line ]]; then
      local name="$line"
      IFS= read -r device || break
      device=$(echo "$device" | tr -d '\t' | head -1)
      [[ -n $device ]] && echo "$device  $name"
    fi
  done
}

show_webcam_select_menu() {
  local devices=$(get_webcam_list)
  local count=$(echo "$devices" | grep -c . 2>/dev/null || echo 0)

  if [[ -z $devices ]] || ((count == 0)); then
    notify-send "No webcam devices found" -u critical -t 3000
    return 1
  fi

  if ((count == 1)); then
    echo "$devices" | awk '{print $1}'
  else
    local selected
    selected=$(menu "Select Webcam" "$devices")

    if [[ $selected == "$MENU_BACK" || $selected == "$MENU_EXIT" || -z $selected ]]; then
      return 1
    fi

    echo "$selected" | awk '{print $1}'
  fi
}

show_screenrecord_menu() {
  leenium-cmd-screenrecord --stop-recording && exit 0

  case $(menu "Screenrecord" "пҖҪ  With no audio\nпҖҪ  With desktop audio\nпҖҪ  With desktop + microphone audio\nпҖҪ  With desktop + microphone audio + webcam") in
  "$MENU_BACK") back_to show_capture_menu ;;
  "$MENU_EXIT") exit 0 ;;
  *"With no audio") leenium-cmd-screenrecord ;;
  *"With desktop audio") leenium-cmd-screenrecord --with-desktop-audio ;;
  *"With desktop + microphone audio") leenium-cmd-screenrecord --with-desktop-audio --with-microphone-audio ;;
  *"With desktop + microphone audio + webcam")
    local device=$(show_webcam_select_menu) || {
      back_to show_capture_menu
      return
    }
    leenium-cmd-screenrecord --with-desktop-audio --with-microphone-audio --with-webcam --webcam-device="$device"
    ;;
  *) back_to show_capture_menu ;;
  esac
}

show_share_menu() {
  case $(menu "Share" "пҒҝ  Clipboard\nо©»  File \nп„”  Folder") in
  "$MENU_BACK") back_to show_action_menu ;;
  "$MENU_EXIT") exit 0 ;;
  *Clipboard*) leenium-cmd-share clipboard ;;
  *File*) terminal bash -c "leenium-cmd-share file" ;;
  *Folder*) terminal bash -c "leenium-cmd-share folder" ;;
  *) back_to show_action_menu ;;
  esac
}

show_toggle_menu() {
  case $(menu "Toggle" "уұ„„  Screensaver\nу°”Һ  Nightlight\nуұ«–  Idle Lock\nу°Қң  Top Bar\nуұӮ¬  Workspace Layout\nоҳӘ  Window Gaps\nпӢҗ  1-Window Ratio\nу°Қ№  Display Scaling") in
  "$MENU_BACK") back_to show_action_menu ;;
  "$MENU_EXIT") exit 0 ;;
  *Screensaver*) leenium-toggle-screensaver ;;
  *Nightlight*) leenium-toggle-nightlight ;;
  *Idle*) leenium-toggle-idle ;;
  *Bar*) leenium-toggle-waybar ;;
  *Layout*) leenium-hyprland-workspace-layout-toggle ;;
  *Ratio*) leenium-hyprland-window-single-square-aspect-toggle ;;
  *Gaps*) leenium-hyprland-window-gaps-toggle ;;
  *Scaling*) leenium-hyprland-monitor-scaling-cycle ;;
  *) back_to show_action_menu ;;
  esac
}

show_hardware_menu() {
  case $(menu "Hardware" "о°ҷ  Hybrid GPU") in
  "$MENU_BACK") show_settings_menu ;;
  "$MENU_EXIT") exit 0 ;;
  *"Hybrid GPU"*) present_terminal leenium-toggle-hybrid-gpu ;;
  *) show_settings_menu ;;
  esac
}

show_appearance_menu() {
  case $(menu "Appearance" "у°ёҢ  Theme\nоҷҷ  Font\nпҖҫ  Background\nпҚҷ  Hyprland\nуұ„„  Screensaver\nо©ҙ  About") in
  "$MENU_BACK") show_main_menu ;;
  "$MENU_EXIT") exit 0 ;;
  *Theme*) show_theme_menu ;;
  *Font*) show_font_menu ;;
  *Background*) show_background_menu ;;
  *Hyprland*) open_in_editor ~/.config/hypr/looknfeel.conf ;;
  *Screensaver*) open_in_editor ~/.config/leenium/branding/screensaver.txt ;;
  *About*) open_in_editor ~/.config/leenium/branding/about.txt ;;
  *) show_main_menu ;;
  esac
}

show_theme_menu() {
  leenium-launch-walker -m menus:leeniumthemes --width 800 --minheight 400
}

show_background_menu() {
  leenium-launch-walker -m menus:leeniumBackgroundSelector --width 800 --minheight 400
}

show_font_menu() {
  theme=$(menu "Font" "$(leenium-font-list)" "--width 350" "$(leenium-font-current)")
  if [[ $theme == "CNCLD" || -z $theme ]]; then
    back_to show_appearance_menu
  else
    leenium-font-set "$theme"
  fi
}

show_settings_menu() {
  local options="у°ҳҰ  Config\nуұҢЈ  Maintenance\nоҳё  Audio\nпҲҺ  Connectivity\nуұҗӢ  Power Profile\nпҖ‘  System Sleep"
  options="$options\nу°Қ№  Monitors\nоҪ°  Hardware\nп„ң  Key Remapping\nу°ұ”  DNS\nо¬‘  Security"

  case $(menu "Settings" "$options") in
  "$MENU_BACK") show_main_menu ;;
  "$MENU_EXIT") exit 0 ;;
  *Config*) show_config_menu ;;
  *Maintenance*) show_maintenance_menu ;;
  *Audio*) leenium-launch-audio ;;
  *Connectivity*) show_connectivity_menu ;;
  *Power*) show_setup_power_menu ;;
  *System*) show_setup_system_menu ;;
  *Monitors*) nwg-displays;;
  *Hardware*) show_hardware_menu ;;
  *Key\ Remapping*) leenium-setup-makima && open_in_editor "$HOME/.config/makima/AT Translated Set 2 keyboard.toml" && leenium-restart-makima ;;
  *DNS*) present_terminal leenium-setup-dns ;;
  *Security*) show_setup_security_menu ;;
  *) show_main_menu ;;
  esac
}

show_config_menu() {
  local options="оҳ•  Core Config"
  [[ -f ~/.config/hypr/bindings.conf ]] && options="$options\nп„ң  Keybindings"
  [[ -f ~/.config/hypr/input.conf ]] && options="$options\nоҫә  Input"

  case $(menu "Config" "$options") in
  "$MENU_BACK") show_settings_menu ;;
  "$MENU_EXIT") exit 0 ;;
  *"Core Config"*) show_setup_config_menu ;;
  *Keybindings*) open_in_editor ~/.config/hypr/bindings.conf ;;
  *Input*) open_in_editor ~/.config/hypr/input.conf ;;
  *) show_settings_menu ;;
  esac
}

show_setup_power_menu() {
  profile=$(menu "Power Profile" "$(leenium-powerprofiles-list)" "" "$(powerprofilesctl get)")

  if [[ $profile == "CNCLD" || -z $profile ]]; then
    back_to show_settings_menu
  else
    powerprofilesctl set "$profile"
  fi
}

show_setup_security_menu() {
  case $(menu "Security" "у°Ҳ·  Fingerprint\nо¬‘  Fido2") in
  "$MENU_BACK") show_settings_menu ;;
  "$MENU_EXIT") exit 0 ;;
  *Fingerprint*) present_terminal leenium-setup-fingerprint ;;
  *Fido2*) present_terminal leenium-setup-fido2 ;;
  *) show_settings_menu ;;
  esac
}

show_setup_config_menu() {
  case $(menu "Config" "п’ү  Defaults\nпҚҷ  Hyprland\nпҚҷ  Hypridle\nпҚҷ  Hyprlock\nпҚҷ  Hyprsunset\nпҚқ  Swayosd\nу°Ң§  Walker\nу°Қң  Waybar\nу°һ…  XCompose") in
  "$MENU_BACK") show_config_menu ;;
  "$MENU_EXIT") exit 0 ;;
  *Defaults*) open_in_editor ~/.config/uwsm/default ;;
  *Hyprland*) open_in_editor ~/.config/hypr/hyprland.conf ;;
  *Hypridle*) open_in_editor ~/.config/hypr/hypridle.conf && leenium-restart-hypridle ;;
  *Hyprlock*) open_in_editor ~/.config/hypr/hyprlock.conf ;;
  *Hyprsunset*) open_in_editor ~/.config/hypr/hyprsunset.conf && leenium-restart-hyprsunset ;;
  *Swayosd*) open_in_editor ~/.config/swayosd/config.toml && leenium-restart-swayosd ;;
  *Walker*) open_in_editor ~/.config/walker/config.toml && leenium-restart-walker ;;
  *Waybar*) open_in_editor ~/.config/waybar/config.jsonc && leenium-restart-waybar ;;
  *XCompose*) open_in_editor ~/.XCompose && leenium-restart-xcompose ;;
  *) show_config_menu ;;
  esac
}

show_setup_system_menu() {
  local options=""

  if [[ -f ~/.local/state/leenium/toggles/suspend-off ]]; then
    options="$optionsу°’І  Enable Suspend"
  else
    options="$optionsу°’І  Disable Suspend"
  fi

  if leenium-hibernation-available; then
    options="$options\nу°ӨҒ  Disable Hibernate"
  else
    options="$options\nу°ӨҒ  Enable Hibernate"
  fi

  case $(menu "System" "$options") in
  "$MENU_BACK") show_settings_menu ;;
  "$MENU_EXIT") exit 0 ;;
  *Suspend*) leenium-toggle-suspend ;;
  *"Enable Hibernate"*) present_terminal leenium-hibernation-setup ;;
  *"Disable Hibernate"*) present_terminal leenium-hibernation-remove ;;
  *) show_settings_menu ;;
  esac
}

show_install_menu() {
  case $(menu "Install" "у°ЈҮ  PACMAN\nу°ЈҮ  AUR\nпүЁ  Web App\nп’ү  TUI\nп’Ү  Service\nоҜҸ  Style\nу°ө®  Development\nп…ң  Editor\nп’ү  Terminal\nуұҡӨ  AI\nу°ҚІ  Windows\nп„ӣ  Gaming") in
  *PACMAN*) terminal leenium-pkg-install ;;
  *AUR*) terminal leenium-pkg-aur-install ;;
  *Web*) present_terminal leenium-webapp-install ;;
  *TUI*) present_terminal leenium-tui-install ;;
  *Service*) show_install_service_menu ;;
  *Style*) show_install_style_menu ;;
  *Development*) show_install_development_menu ;;
  *Editor*) show_install_editor_menu ;;
  *Terminal*) show_install_terminal_menu ;;
  *AI*) show_install_ai_menu ;;
  *Windows*) present_terminal "leenium-windows-vm install" ;;
  *Gaming*) show_install_gaming_menu ;;
  *) show_main_menu ;;
  esac
}

