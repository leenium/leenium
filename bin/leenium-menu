  *Ghostty*) install_terminal "ghostty" ;;
  *Kitty*) install_terminal "kitty" ;;
  *) show_install_menu ;;
  esac
}

show_install_ai_menu() {
  ollama_pkg=$(
    (command -v nvidia-smi &>/dev/null && echo ollama-cuda) ||
      (command -v rocminfo &>/dev/null && echo ollama-rocm) ||
      echo ollama
  )

  case $(menu "Install" "уұҡӨ  Claude Code\nуұҡӨ  Codex\nуұҡӨ  Crush\nо°’  Dictation\nуұҡӨ  Gemini CLI\nуұҡӨ  Ollama\nуұҡӨ  OpenCode\nуұҡӨ  LM Studio (AUR)") in
  *Claude*) present_terminal "leenium-install-dev-env claude-code" ;;
  *Codex*) present_terminal "leenium-install-dev-env codex" ;;
  *Crush*) present_terminal "leenium-install-dev-env crush" ;;
  *Dictation*) present_terminal leenium-voxtype-install ;;
  *Gemini*) present_terminal "leenium-install-dev-env gemini-cli" ;;
  *Ollama*) install "Ollama" $ollama_pkg ;;
  *OpenCode*) present_terminal "leenium-install-dev-env opencode" ;;
  *Studio*) present_terminal "leenium-pkg-aur-add lmstudio-bin" ;;
  *) show_install_menu ;;
  esac
}

