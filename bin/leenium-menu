  case $(menu "Install" "  Clojure\n  Docker DB\n  Elixir\n  Go\n  Java\n  JavaScript\n  .NET\n  OCaml\n  PHP\n  Python\n󰫏  Ruby on Rails\n  Rust\n  Scala\n  Zig") in
