#!/bin/bash

LEENIUM_PATH=${LEENIUM_PATH:-$HOME/.local/share/leenium}
export PATH="$LEENIUM_PATH/bin:$PATH"

STATE_DIR="$HOME/.local/state/leenium"
MIGRATIONS_STATE_DIR="$STATE_DIR/migrations"
USER_CONFIG_DIR="$HOME/.config"
USER_LEENIUM_DIR="$USER_CONFIG_DIR/leenium"

PASS_COUNT=0
WARN_COUNT=0
FAIL_COUNT=0

QUICK_MODE=false
JSON_OUTPUT=false
TARGET_SECTION=""
SECTION_RESULTS="{}"
LIVE_OUTPUT=false
SPINNER_ACTIVE=false
SPINNER_INDEX=0
CURRENT_SECTION=""
SPINNER_FRAMES=('⠋ ' '⠙ ' '⠹ ' '⠼ ' '⠶ ' '⠧ ' '⠏ ')

repeat_char() {
  local char="$1"
  local count="$2"
  local out=""

  while (( count > 0 )); do
    out+="$char"
    ((count--))
  done

  printf '%s' "$out"
}

ui_width() {
  local width=72

  if command -v tput >/dev/null 2>&1; then
    width=$(tput cols 2>/dev/null || echo 72)
  fi

  if [[ ! $width =~ ^[0-9]+$ ]]; then
    width=72
  fi

  if (( width < 48 )); then
    width=48
  elif (( width > 96 )); then
    width=96
  fi

  echo "$width"
}

print_section_header() {
  local title="$1"
  local width
  local line

  width=$(ui_width)
  line=$(repeat_char "─" "$width")

  echo
  echo -e "\e[2;37m$line\e[0m"
  echo -e "\e[1;36m  $title\e[0m"
}

print_summary_line() {
  local icon="$1"
  local color="$2"
  local label="$3"
  local value="$4"

  echo -e "  \e[${color}m${icon}\e[0m  ${label} ${value}"
}

print_result_line() {
  local icon="$1"
  local color="$2"
  local status="$3"
  local message="$4"

  printf '\e[%sm%-2s %-5s\e[0m %s\n' "$color" "$icon" "$status" "$message"
}

python_syntax_ok() {
  local script="$1"

  python3 -c 'import pathlib, sys; compile(pathlib.Path(sys.argv[1]).read_text(), sys.argv[1], "exec")' "$script" >/dev/null 2>&1
}

print_usage() {
  cat <<EOF
Usage: leenium-doctor [OPTIONS]

Checks the local Leenium installation for common configuration, theme, migration,
and service problems.

Options:
  --quick        Skip script syntax checks for faster execution
  --json         Output results in JSON format
  --section SEC  Run only the specified section (e.g., --section scripts)
  -h, --help     Show this help message

Sections: install, commands, config, apps, rollback, theme, migrations,
          services, git, scripts, hooks, variables, dependencies,
          desktop, network, disk, permissions
EOF
}

while (( $# > 0 )); do
  case "$1" in
    -h|--help)
      print_usage
      exit 0
      ;;
    --quick)
      QUICK_MODE=true
      ;;
    --json)
      JSON_OUTPUT=true
      ;;
    --section)
      TARGET_SECTION="$2"
      shift
      ;;
    *)
      echo "Unknown option: $1"
      echo
      print_usage
      exit 1
      ;;
  esac
  shift
done

if [[ "$JSON_OUTPUT" != "true" && -t 1 ]]; then
  LIVE_OUTPUT=true
fi

clear_live_line() {
  [[ "$LIVE_OUTPUT" == "true" ]] || return 0

  if [[ "$SPINNER_ACTIVE" == "true" ]]; then
    printf '\r\033[2K'
    SPINNER_ACTIVE=false
  fi
}

render_spinner_frame() {
  local message="$1"

  [[ "$LIVE_OUTPUT" == "true" ]] || return 0

  printf '\r\033[2K\e[36m%s\e[0m %s' "${SPINNER_FRAMES[SPINNER_INDEX]}" "$message"
  SPINNER_ACTIVE=true
}

advance_spinner_frame() {
  SPINNER_INDEX=$(( (SPINNER_INDEX + 1) % ${#SPINNER_FRAMES[@]} ))
}

with_spinner() {
  local message="$1"
  shift
  local cmd_pid
  local status

  if [[ "$LIVE_OUTPUT" != "true" ]]; then
    "$@"
    return $?
  fi

  "$@" &
  cmd_pid=$!

  while kill -0 "$cmd_pid" >/dev/null 2>&1; do
    render_spinner_frame "$message"
    sleep 0.1
    advance_spinner_frame
  done

  wait "$cmd_pid"
  status=$?
  clear_live_line
  return $status
}

announce_check() {
  local message="$1"

  [[ "$LIVE_OUTPUT" == "true" ]] || return 0
  render_spinner_frame "$message"
  advance_spinner_frame
}

run_section() {
  local section_name="$1"
  local section_func="$2"

  if [[ -n $TARGET_SECTION ]]; then
    if [[ "$TARGET_SECTION" == "$section_name" ]]; then
      $section_func
    fi
  else
    $section_func
  fi
}

pass() {
  local msg="$1"
  if [[ "$JSON_OUTPUT" == "true" ]]; then
    echo "{\"status\":\"pass\",\"message\":\"$msg\"}"
  else
    clear_live_line
    print_result_line "✓" "32" "PASS" "$1"
  fi
  ((PASS_COUNT++))
}

warn() {
  local msg="$1"
  if [[ "$JSON_OUTPUT" == "true" ]]; then
    echo "{\"status\":\"warn\",\"message\":\"$msg\"}"
  else
    clear_live_line
    print_result_line "!" "33" "WARN" "$1"
  fi
  ((WARN_COUNT++))
}

fail() {
  local msg="$1"
  if [[ "$JSON_OUTPUT" == "true" ]]; then
    echo "{\"status\":\"fail\",\"message\":\"$msg\"}"
  else
    clear_live_line
    print_result_line "✗" "31" "FAIL" "$1"
  fi
  ((FAIL_COUNT++))
}

section() {
  if [[ "$JSON_OUTPUT" != "true" ]]; then
    clear_live_line
    print_section_header "$1"
  fi
  CURRENT_SECTION="$1"
}

desktop_exec_binary() {
  local desktop_file="$1"
  local exec_line
  local exec_command
  local exec_binary

  exec_line=$(sed -n 's/^Exec=//p' "$desktop_file" 2>/dev/null | head -1)
  [[ -n $exec_line ]] || return 1

  exec_command=${exec_line%% *}
  exec_command=${exec_command%%\%*}
  exec_binary=$(basename "$exec_command")

  [[ -n $exec_binary ]] || return 1
  echo "$exec_binary"
}

desktop_exec_line() {
  local desktop_file="$1"

  sed -n 's/^Exec=//p' "$desktop_file" 2>/dev/null | head -1
}

check_desktop_entry() {
  local desktop_file="$1"
  local label="$2"
  local icon_line
  local icon_path
  local exec_binary

  announce_check "Checking $label desktop entry"
  if [[ ! -f $desktop_file ]]; then
    fail "$label desktop entry missing ($desktop_file)"
    return
  fi

  pass "$label desktop entry present"

  exec_binary=$(desktop_exec_binary "$desktop_file")
  if [[ -n $exec_binary ]]; then
    if leenium-cmd-present "$exec_binary"; then
      pass "$label launcher command available ($exec_binary)"
    else
      warn "$label launcher command missing ($exec_binary)"
    fi
  else
    warn "$label desktop entry has no readable Exec line"
  fi

  icon_line=$(sed -n 's/^Icon=//p' "$desktop_file" 2>/dev/null | head -1)
  if [[ -n $icon_line && $icon_line == /* ]]; then
    icon_path=${icon_line/%\%*/}
    if [[ -f $icon_path ]]; then
      pass "$label icon present"
    else
      warn "$label icon missing ($icon_path)"
    fi
  fi
}

find_desktop_entry_file() {
  local desktop_id="$1"
  local base

  for base in "$HOME/.local/share/applications" "$HOME/.nix-profile/share/applications" "/usr/local/share/applications" "/usr/share/applications"; do
    if [[ -f $base/$desktop_id ]]; then
      echo "$base/$desktop_id"
      return 0
    fi
  done

  return 1
}

check_system_service_if_installed() {
  local cmd="$1"
  local unit="$2"
  local label="$3"
  local state

  announce_check "Checking $label service"
  if ! leenium-cmd-present "$cmd"; then
    clear_live_line
    return
  fi

  if ! systemctl list-unit-files --all 2>/dev/null | grep -q "^$unit "; then
    warn "$label service unit not found ($unit)"
    return
  fi

  state=$(systemctl is-enabled "$unit" 2>/dev/null || true)
  case "$state" in
    enabled)
      pass "$label service enabled ($unit)"
      ;;
    static|indirect|generated|alias)
      pass "$label service installed ($unit)"
      ;;
    disabled)
      warn "$label service installed but disabled ($unit)"
      ;;
    *)
      warn "$label service state unknown ($unit)"
      ;;
  esac
}

check_dir() {
  local path="$1"
  local label="$2"

  if with_spinner "Checking $label" test -d "$path"; then
    pass "$label present ($path)"
  else
    fail "$label missing ($path)"
  fi
}

check_file() {
  local path="$1"
  local label="$2"

  if with_spinner "Checking $label" test -f "$path"; then
    pass "$label present ($path)"
  else
    fail "$label missing ($path)"
  fi
}

check_command() {
  local cmd="$1"
  local label="$2"

  if with_spinner "Checking $label" leenium-cmd-present "$cmd"; then
    pass "$label available ($cmd)"
  else
    fail "$label missing ($cmd)"
  fi
}

system_unit_exists() {
  local unit="$1"

  systemctl list-unit-files --all 2>/dev/null | grep -q "^$unit "
}

section_install() {
  section "Install"
  check_dir "$LEENIUM_PATH" "Leenium root"
  check_dir "$LEENIUM_PATH/bin" "Command directory"
  check_dir "$LEENIUM_PATH/themes" "Theme directory"
  check_dir "$LEENIUM_PATH/default" "Default payload directory"
  check_file "$LEENIUM_PATH/version" "Version file"

  announce_check "Checking PATH integration"
  if [[ :$PATH: == *":$LEENIUM_PATH/bin:"* ]]; then
    pass "Leenium bin directory is on PATH"
  else
    warn "Leenium bin directory is not on PATH"
  fi

  announce_check "Checking installed version"
  if [[ -f $LEENIUM_PATH/version ]]; then
    version=$(<"$LEENIUM_PATH/version")
    if [[ -n $version ]]; then
      pass "Version detected ($version)"
    else
      fail "Version file is empty"
    fi
  fi
}

section_commands() {
  section "Commands"
  check_command git "Git"
  check_command gum "Gum"
  check_command walker "Walker"
  check_command hyprctl "Hyprland control"
  check_command systemctl "Systemd"
  check_command leenium-theme-set "Theme command"
  check_command leenium-refresh-config "Refresh command"
  check_command leenium-update "Update command"
  check_command leenium-update-history "Update history command"
  check_command leenium-rollback "Rollback command"
}

section_config() {
  section "Config"
  check_dir "$USER_LEENIUM_DIR" "User Leenium config"
  check_dir "$USER_LEENIUM_DIR/current" "Active Leenium state"
  check_file "$USER_LEENIUM_DIR/current/theme.name" "Active theme marker"
  check_file "$USER_CONFIG_DIR/hypr/hyprland.conf" "Hyprland config"
  check_file "$USER_CONFIG_DIR/hypr/hyprlock.conf" "Hyprlock config"
  check_file "$USER_CONFIG_DIR/waybar/config.jsonc" "Waybar config"
  check_file "$USER_CONFIG_DIR/walker/config.toml" "Walker config"
}

section_apps() {
  section "Apps"
  announce_check "Checking preferred terminal"
  if [[ -f $USER_CONFIG_DIR/xdg-terminals.list ]]; then
    terminal_desktop_id=$(sed -n '/^[^#[:space:]]/p' "$USER_CONFIG_DIR/xdg-terminals.list" | head -1)

    if [[ -n $terminal_desktop_id ]]; then
      terminal_desktop_file=$(find_desktop_entry_file "$terminal_desktop_id" || true)
      if [[ -n $terminal_desktop_file ]]; then
        check_desktop_entry "$terminal_desktop_file" "Preferred terminal"
      else
        fail "Preferred terminal desktop entry missing ($terminal_desktop_id)"
      fi
    else
      warn "xdg-terminals.list exists but no preferred terminal is set"
    fi
  else
    warn "No xdg terminal preference file found"
  fi

  announce_check "Checking default browser"
  default_browser=$(xdg-settings get default-web-browser 2>/dev/null || true)
  if [[ -n $default_browser ]]; then
    default_browser_file=$(find_desktop_entry_file "$default_browser" || true)
    if [[ -n $default_browser_file ]]; then
      check_desktop_entry "$default_browser_file" "Default browser"
    else
      fail "Default browser desktop entry missing ($default_browser)"
    fi
  else
    warn "No default browser is configured"
  fi

  announce_check "Checking editor command"
  editor_binary=${EDITOR:-nvim}
  if leenium-cmd-present "$editor_binary"; then
    pass "Editor available ($editor_binary)"
  else
    warn "Editor command missing ($editor_binary)"
  fi

  announce_check "Checking voxtype integration"
  if [[ -f $HOME/.config/voxtype/config.toml ]]; then
    if leenium-cmd-present voxtype wtype; then
      pass "Voxtype integration dependencies available"
    else
      fail "Voxtype is configured but required commands are missing"
    fi
  fi

  announce_check "Checking Tailscale"
  if leenium-cmd-present tailscale; then
    pass "Tailscale installed"
    check_system_service_if_installed tailscale tailscaled.service "Tailscale"

    if [[ -f $HOME/.local/share/applications/Tailscale.desktop ]]; then
      check_desktop_entry "$HOME/.local/share/applications/Tailscale.desktop" "Tailscale web app"
    fi
  fi

  announce_check "Checking Docker"
  if leenium-cmd-present docker; then
    pass "Docker installed"

    if docker ps >/dev/null 2>&1; then
      pass "Docker daemon reachable"
    else
      docker_service_state=""
      docker_socket_state=""

      if system_unit_exists docker.service; then
        docker_service_state=$(systemctl is-enabled docker.service 2>/dev/null || true)
      fi

      if system_unit_exists docker.socket; then
        docker_socket_state=$(systemctl is-enabled docker.socket 2>/dev/null || true)
      fi

      if [[ $docker_service_state == "enabled" ]] || [[ $docker_socket_state == "enabled" ]]; then
        warn "Docker is installed but the daemon is not reachable for the current user"
      elif [[ -n $docker_service_state ]] || [[ -n $docker_socket_state ]]; then
        warn "Docker is installed but neither docker.service nor docker.socket is enabled"
      else
        warn "Docker installed but no docker systemd unit was found"
      fi
    fi
  fi

  steam_desktop_file=$(find_desktop_entry_file steam.desktop || true)
  if [[ -n $steam_desktop_file ]]; then
    check_desktop_entry "$steam_desktop_file" "Steam"
  elif leenium-cmd-present steam; then
    pass "Steam command available"
  fi

  lutris_desktop_file=$(find_desktop_entry_file net.lutris.Lutris.desktop || true)
  if [[ -n $lutris_desktop_file ]]; then
    check_desktop_entry "$lutris_desktop_file" "Lutris"
  elif leenium-cmd-present lutris; then
    pass "Lutris command available"
  fi

  gfn_desktop_file=$(find_desktop_entry_file com.nvidia.geforcenow.desktop || true)
  if [[ -z $gfn_desktop_file ]]; then
    gfn_desktop_file=$(find_desktop_entry_file GeForceNOW.desktop || true)
  fi

  if [[ -n $gfn_desktop_file ]]; then
    check_desktop_entry "$gfn_desktop_file" "GeForce NOW"
  fi

  local_app_count=0
  broken_local_apps=0
  announce_check "Scanning local application launchers"
  while IFS= read -r desktop_file; do
    [[ -n $desktop_file ]] || continue
    app_name=$(basename "$desktop_file")
    exec_line=$(desktop_exec_line "$desktop_file")
    icon_line=$(sed -n 's/^Icon=//p' "$desktop_file" 2>/dev/null | head -1)

    if [[ $exec_line != leenium-* ]] && [[ $exec_line != xdg-terminal-exec* ]] && [[ $icon_line != $HOME/.local/share/applications/icons/* ]]; then
      continue
    fi

    ((local_app_count++))
    exec_binary=$(desktop_exec_binary "$desktop_file")

    if [[ -z $exec_binary ]]; then
      warn "Local app $app_name has no readable Exec line"
      ((broken_local_apps++))
      continue
    fi

    if [[ $exec_binary == "leenium-launch-webapp" || $exec_binary == "xdg-terminal-exec" || $exec_binary == "gtk-launch" || $exec_binary == "uwsm-app" ]]; then
      pass "Local app $app_name has a recognized launcher"
    elif leenium-cmd-present "$exec_binary"; then
      pass "Local app $app_name command available ($exec_binary)"
    else
      warn "Local app $app_name command missing ($exec_binary)"
      ((broken_local_apps++))
    fi

    if [[ -n $icon_line && $icon_line == /* && ! -f $icon_line ]]; then
      warn "Local app $app_name icon missing ($icon_line)"
      ((broken_local_apps++))
    fi
  done < <(find "$HOME/.local/share/applications" -maxdepth 1 -type f -name '*.desktop' 2>/dev/null | sort)

  if (( local_app_count == 0 )); then
    pass "No local application launchers to validate"
  elif (( broken_local_apps == 0 )); then
    pass "All local application launchers look valid"
  fi
}

section_rollback() {
  section "Rollback"
  history_file="$STATE_DIR/update-history.tsv"

  announce_check "Checking rollback history"
  if [[ -f $history_file ]]; then
    pass "Update history file present ($history_file)"

    history_columns=$(awk -F'\t' 'NF > max { max = NF } END { print max + 0 }' "$history_file")
    if (( history_columns >= 12 )); then
      pass "Update history format includes snapshot IDs"
    elif (( history_columns >= 11 )); then
      warn "Update history exists but uses the older format without snapshot IDs"
    else
      warn "Update history file format looks incomplete"
    fi
  else
    warn "No update history file found yet"
  fi

  announce_check "Checking update history command"
  if leenium-update-history --json >/dev/null 2>&1; then
    pass "Update history JSON output works"
  else
    fail "Update history JSON output failed"
  fi

  announce_check "Checking Snapper rollback support"
  if leenium-cmd-present snapper; then
    pass "Snapper available for rollback"

    if leenium-cmd-present limine-snapper-restore; then
      pass "limine-snapper-restore available"
    else
      warn "limine-snapper-restore missing"
    fi

    if sudo snapper --csvout --no-headers list-configs >/dev/null 2>&1; then
      pass "Snapper configs are readable"
    else
      warn "Snapper is installed but configs could not be read"
    fi

    if sudo snapper -c root --csvout --no-headers list --columns number >/dev/null 2>&1; then
      pass "Root snapshots are listable"
    else
      warn "Snapper root snapshots could not be listed"
    fi
  else
    warn "Snapper not installed, rollback is unavailable"
  fi
}

section_theme() {
  section "Theme"
  missing_theme_assets=0

  announce_check "Checking built-in themes"
  while IFS= read -r theme_dir; do
    [[ -n $theme_dir ]] || continue

    if [[ ! -f $theme_dir/colors.toml ]]; then
      fail "Theme $(basename "$theme_dir") is missing colors.toml"
      ((missing_theme_assets++))
    fi

    if [[ ! -f $theme_dir/preview.png ]]; then
      warn "Theme $(basename "$theme_dir") is missing preview.png"
    fi
  done < <(find "$LEENIUM_PATH/themes" -mindepth 1 -maxdepth 1 -type d | sort)

  if (( missing_theme_assets == 0 )); then
    pass "All built-in themes include colors.toml"
  fi

  announce_check "Checking active theme"
  current_theme_name=""
  if [[ -f $USER_LEENIUM_DIR/current/theme.name ]]; then
    current_theme_name=$(<"$USER_LEENIUM_DIR/current/theme.name")
  fi

  if [[ -n $current_theme_name ]]; then
    if [[ -d $USER_LEENIUM_DIR/current/theme ]]; then
      pass "Active theme directory exists"
    else
      fail "Active theme directory missing ($USER_LEENIUM_DIR/current/theme)"
    fi

    if [[ -d $LEENIUM_PATH/themes/$current_theme_name ]] || [[ -d $USER_LEENIUM_DIR/themes/$current_theme_name ]]; then
      pass "Active theme source exists ($current_theme_name)"
    else
      fail "Active theme source missing ($current_theme_name)"
    fi

    if [[ -f $USER_LEENIUM_DIR/current/theme/colors.toml ]]; then
      pass "Active theme colors.toml present"
    else
      warn "Active theme colors.toml missing"
    fi
  else
    warn "No active theme is recorded"
  fi

  announce_check "Checking theme templates"
  template_count=$(find "$LEENIUM_PATH/default/themed" -maxdepth 1 -type f -name '*.tpl' | wc -l)
  if (( template_count > 0 )); then
    pass "Theme templates present ($template_count files)"
  else
    fail "No theme templates found in $LEENIUM_PATH/default/themed"
  fi
}

section_migrations() {
  section "Migrations"
  announce_check "Checking migrations"
  migration_total=$(find "$LEENIUM_PATH/migrations" -maxdepth 1 -type f -name '*.sh' 2>/dev/null | wc -l)
  pending_migrations=0
  current_version=""
  previous_version="1.0.0"
  version_state_file="$STATE_DIR/version"

  version_lt() {
    [[ $1 != "$2" ]] && [[ $(printf '%s\n%s\n' "$1" "$2" | sort -V | head -n1) == "$1" ]]
  }

  version_le() {
    [[ $1 == "$2" ]] || [[ $(printf '%s\n%s\n' "$1" "$2" | sort -V | head -n1) == "$1" ]]
  }

  if [[ -f $LEENIUM_PATH/version ]]; then
    current_version=$(<"$LEENIUM_PATH/version")
  fi

  if [[ -f $version_state_file ]]; then
    previous_version=$(<"$version_state_file")
  fi

  while IFS= read -r migration_file; do
    [[ -n $migration_file ]] || continue

    migration_name=$(basename "$migration_file")
    migration_version=$(sed -n 's/^MIGRATION_VERSION="\([^"]*\)"$/\1/p' "$migration_file" | head -n1)

    if [[ -n $current_version && -n $migration_version ]] && (! version_lt "$previous_version" "$migration_version" || ! version_le "$migration_version" "$current_version"); then
      continue
    fi

    if [[ ! -f $MIGRATIONS_STATE_DIR/$migration_name && ! -f $MIGRATIONS_STATE_DIR/skipped/$migration_name ]]; then
      ((pending_migrations++))
    fi
  done < <(find "$LEENIUM_PATH/migrations" -maxdepth 1 -type f -name '*.sh' 2>/dev/null | sort)

  if (( migration_total == 0 )); then
    pass "No migrations are currently shipped"
  elif (( pending_migrations == 0 )); then
    pass "No pending migrations"
  else
    warn "$pending_migrations migration(s) are pending"
  fi
}

section_services() {
  section "Services"
  announce_check "Checking user services"
  if systemctl --user show-environment >/dev/null 2>&1; then
    failed_units=$(systemctl --user --failed --no-legend --plain 2>/dev/null | sed '/^[[:space:]]*$/d')

    if [[ -n $failed_units ]]; then
      warn "User services have failed units"
      echo "$failed_units"
    else
      pass "No failed user services"
    fi

    if systemctl --user list-unit-files | grep -q '^leenium-battery-monitor.timer'; then
      battery_monitor_state=$(systemctl --user is-enabled leenium-battery-monitor.timer 2>/dev/null || true)

      if [[ $battery_monitor_state == "enabled" ]]; then
        pass "leenium-battery-monitor.timer is enabled"
      else
        warn "leenium-battery-monitor.timer is not enabled"
      fi
    else
      warn "leenium-battery-monitor.timer is not installed for this user"
    fi
  else
    warn "systemctl --user is not available in this session"
  fi
}

section_git() {
  section "Git"
  announce_check "Checking git state"
  if git -C "$LEENIUM_PATH" rev-parse --is-inside-work-tree >/dev/null 2>&1; then
    pass "Leenium root is a git repository"

    branch=$(git -C "$LEENIUM_PATH" branch --show-current 2>/dev/null || true)
    if [[ -n $branch ]]; then
      pass "Current branch: $branch"
    fi

    if [[ -n $(git -C "$LEENIUM_PATH" status --short 2>/dev/null) ]]; then
      warn "Leenium git tree has uncommitted changes"
    else
      pass "Leenium git tree is clean"
    fi
  else
    warn "Leenium root is not a git repository"
  fi
}

section_scripts() {
  section "Scripts"

  if [[ "$QUICK_MODE" == "true" ]]; then
    pass "Scripts check skipped (--quick mode)"
    return
  fi

  script_count=0
  syntax_errors=0
  permission_errors=0
  trailing_whitespace=0
  announce_check "Scanning Leenium scripts"

  while IFS= read -r script; do
    [[ -n $script ]] || continue
    ((script_count++))

    first_line=$(head -1 "$script")
    shebang_ok=false
    if [[ "$first_line" =~ ^#!/(bin/bash|usr/bin/env bash) ]]; then
      shebang_ok=true
      if ! bash -n "$script" 2>/dev/null; then
        fail "$(basename "$script"): syntax error"
        ((syntax_errors++))
      fi
    elif [[ "$first_line" =~ ^#!/(bin/python3?|usr/bin/env python3?) ]]; then
      shebang_ok=true
      if command -v python3 >/dev/null 2>&1 && ! python_syntax_ok "$script"; then
        fail "$(basename "$script"): syntax error"
        ((syntax_errors++))
      fi
    fi

    if ! $shebang_ok; then
      warn "$(basename "$script"): missing or invalid shebang"
    fi

    if [[ ! -x "$script" ]]; then
      warn "$(basename "$script"): not executable"
      ((permission_errors++))
    fi

    if grep -q '[[:space:]]$' "$script" 2>/dev/null; then
      warn "$(basename "$script"): contains trailing whitespace"
      ((trailing_whitespace++))
    fi
  done < <(find "$LEENIUM_PATH/bin" -maxdepth 1 -type f -name 'leenium-*' 2>/dev/null | sort)

  if (( script_count > 0 )); then
    if (( syntax_errors == 0 )); then
      pass "All $script_count scripts have valid syntax"
    fi
    if (( permission_errors == 0 )); then
      pass "All scripts have correct permissions"
    fi
  else
    warn "No leenium scripts found in $LEENIUM_PATH/bin"
  fi
}

section_hooks() {
  section "Hooks"
  hooks_dir="$HOME/.config/leenium/hooks"

  if [[ ! -d $hooks_dir ]]; then
    pass "No custom hooks directory (optional)"
    return
  fi

  hook_count=0
  hook_errors=0
  announce_check "Scanning custom hooks"

  while IFS= read -r hook; do
    [[ -n $hook ]] || continue

    if [[ "$hook" == *.sample ]]; then
      continue
    fi

    ((hook_count++))

    if [[ ! -x "$hook" ]]; then
      warn "$(basename "$hook"): hook not executable"
      ((hook_errors++))
    fi

    if ! bash -n "$hook" 2>/dev/null; then
      fail "$(basename "$hook"): hook has syntax error"
      ((hook_errors++))
    fi
  done < <(find "$hooks_dir" -maxdepth 1 -type f 2>/dev/null | sort)

  if (( hook_count > 0 )); then
    if (( hook_errors == 0 )); then
      pass "All $hook_count hooks are valid"
    fi
  fi
}

section_variables() {
  section "Variable Safety"

  scanned_scripts=0
  suspicious_count=0
  announce_check "Scanning scripts for unsafe variable usage"

  while IFS= read -r script; do
    [[ -n $script ]] || continue
    ((scanned_scripts++))

    while IFS= read -r line; do
      if [[ "$line" =~ (cat|cp|mv|rm|grep|ls|mkdir|chmod|chown|curl|wget|sudo)\  ]]; then
        warn "$(basename "$script"): potential unquoted variable in command: ${line:0:60}..."
        ((suspicious_count++))
      fi
    done < <(grep -nE '^\s*(cat|cp|mv|rm|grep|ls|mkdir|chmod|chown|curl|wget|sudo)\s+[^"]*\$[A-Za-z_]' "$script" 2>/dev/null || true)
  done < <(find "$LEENIUM_PATH/bin" -maxdepth 1 -type f -name 'leenium-*' 2>/dev/null | sort)

  if (( suspicious_count == 0 )); then
    pass "No obvious unquoted variable issues detected across $scanned_scripts scripts"
  else
    warn "Found $suspicious_count potential unquoted variable issue(s) across $scanned_scripts scripts"
  fi
}

section_dependencies() {
  section "Dependencies"

  required_deps=(
    "sudo:0:Sudo"
    "systemctl:1:Systemctl"
    "pacman:0:Pacman"
    "git:0:Git"
    "gum:0:Gum"
    "hyprctl:0:Hyprctl"
    "waybar:0:Waybar"
    "walker:0:Walker"
    "uwsm:0:UWSM"
    "snapper:0:Snapper"
    "limine-update:0:Limine"
  )

  missing_count=0

  for dep in "${required_deps[@]}"; do
    IFS=':' read -r cmd critical label <<< "$dep"
    announce_check "Checking $label"
    if ! command -v "$cmd" >/dev/null 2>&1; then
      if (( critical )); then
        fail "$label not found ($cmd)"
        ((missing_count++))
      else
        warn "$label not found ($cmd)"
      fi
    else
      pass "$label available"
    fi
  done

  if (( missing_count == 0 )); then
    pass "All required dependencies are installed"
  fi
}

section_desktop() {
  section "Desktop Entries"
  desktop_count=0
  desktop_issue_count=0
  announce_check "Scanning desktop entries"

  while IFS= read -r desktop_file; do
    [[ -n $desktop_file ]] || continue
    ((desktop_count++))

    if [[ -f "$desktop_file" ]]; then
      icon_line=$(sed -n 's/^Icon=//p' "$desktop_file" 2>/dev/null | head -1)
      exec_line=$(sed -n 's/^Exec=//p' "$desktop_file" 2>/dev/null | head -1)

      if [[ -n $icon_line && $icon_line == /* && ! -f "$icon_line" ]]; then
        warn "$(basename "$desktop_file"): icon not found ($icon_line)"
        ((desktop_issue_count++))
      fi

      mime_type=$(sed -n 's/^MimeType=//p' "$desktop_file" 2>/dev/null | head -1)
      if [[ -n $mime_type ]]; then
        IFS=';' read -ra mimes <<< "$mime_type"
        for mime in "${mimes[@]}"; do
          [[ -n $mime ]] || continue
          if ! xdg-mime query default "$(file -b --mime-type "${desktop_file%/*}/.." 2>/dev/null)" "$mime" >/dev/null 2>&1; then
            warn "$(basename "$desktop_file"): mime type $mime may not be registered"
            ((desktop_issue_count++))
          fi
        done
      fi
    fi
  done < <(find "$HOME/.local/share/applications" -maxdepth 1 -type f -name '*.desktop' 2>/dev/null | sort)

  if (( desktop_issue_count == 0 )); then
    pass "Desktop entry validation complete ($desktop_count files checked)"
  else
    warn "Desktop entry validation complete with $desktop_issue_count issue(s) across $desktop_count files"
  fi
}

section_network() {
  section "Network"

  announce_check "Checking package server"
  if command -v curl >/dev/null 2>&1; then
    if curl -s --connect-timeout 5 --max-time 10 -I "https://pkgs.leenium.org/" >/dev/null 2>&1; then
      pass "Package server (pkgs.leenium.org) is reachable"
    else
      warn "Package server (pkgs.leenium.org) is not reachable"
    fi
  else
    warn "curl not available, skipping network check"
  fi

  announce_check "Checking DNS resolution"
  if command -v host >/dev/null 2>&1; then
    if host "leenium.org" >/dev/null 2>&1; then
      pass "DNS resolution for leenium.org works"
    else
      warn "DNS resolution for leenium.org failed"
    fi
  fi
}

section_disk() {
  section "Disk Space"

  check_mount_space() {
    local mount="$1"
    local label="$2"
    local min_mb="$3"

    local avail_kb=$(df -k "$mount" | awk 'NR==2 {print $4}')
    local avail_mb=$((avail_kb / 1024))

    if (( avail_mb < min_mb )); then
      warn "$label has only ${avail_mb}MB free (recommended: ${min_mb}MB)"
    else
      pass "$label has ${avail_mb}MB free"
    fi
  }

  check_mount_space "/" "Root filesystem" 1000
  check_mount_space "/boot" "Boot partition" 100

  announce_check "Checking root filesystem usage"
  usage_percent=$(df / | awk 'NR==2 {print $5}' | tr -d '%')
  if (( usage_percent > 90 )); then
    warn "Root filesystem is ${usage_percent}% full"
  fi
}

section_permissions() {
  section "Permissions"

  check_ownership() {
    local path="$1"
    local label="$2"

    if [[ ! -e "$path" ]]; then
      warn "$label does not exist ($path)"
      return
    fi

    local owner=$(stat -c '%U' "$path" 2>/dev/null)
    local current_user=$(whoami)

    if [[ "$owner" == "$current_user" ]]; then
      pass "$label is owned by user"
    else
      warn "$label is owned by $owner (should be $current_user)"
    fi
  }

  check_ownership "$LEENIUM_PATH" "Leenium installation"
  check_ownership "$HOME/.config/leenium" "User leenium config"
  check_ownership "$HOME/.local/state/leenium" "Leenium state directory"

  if [[ -d "$HOME/.local/state/leenium" ]]; then
    pass "Leenium state directory exists"
  fi
}

if [[ -z $TARGET_SECTION ]]; then
  section_install
  section_commands
  section_config
  section_apps
  section_rollback
  section_theme
  section_migrations
  section_services
  section_git
fi

section_scripts
section_hooks
section_variables
section_dependencies
section_desktop
section_network
section_disk
section_permissions

section "Summary"
if [[ "$JSON_OUTPUT" != "true" ]]; then
  clear_live_line
  print_summary_line "✓" "32" "Passed  " "$PASS_COUNT"
  print_summary_line "!" "33" "Warnings" "$WARN_COUNT"
  print_summary_line "✗" "31" "Failed  " "$FAIL_COUNT"
  echo

  if (( FAIL_COUNT == 0 )) && (( WARN_COUNT == 0 )); then
    echo -e "\e[32m✓ All checks passed!\e[0m"
  elif (( FAIL_COUNT == 0 )); then
    echo -e "\e[33m⚠ Some warnings detected (non-blocking)\e[0m"
  else
    echo -e "\e[31m✗ Fix the issues above before continuing\e[0m"
  fi
else
  echo "{\"total\":{\"pass\":$PASS_COUNT,\"warn\":$WARN_COUNT,\"fail\":$FAIL_COUNT}}"
fi

if (( FAIL_COUNT > 0 )); then
  exit 1
fi
