#!/bin/bash

# Overwrite the user config for the Limine bootloader and rebuild it.

MACHINE_ID=$(cat /etc/machine-id 2>/dev/null || true)
if [[ -n $MACHINE_ID ]] && [[ -f /boot/EFI/Linux/leenium_linux.efi ]] && [[ -f "/boot/EFI/Linux/${MACHINE_ID}_linux.efi" ]]; then
  echo "Cleanup extra UKI"
  sudo rm -f "/boot/EFI/Linux/${MACHINE_ID}_linux.efi"
fi
echo "Resetting limine config"

sudo mv /boot/limine.conf /boot/limine.conf.bak

sudo cp ~/.local/share/leenium/default/limine/limine.conf /boot/limine.conf

sudo limine-update
sudo limine-snapper-sync
