#!/bin/bash

# Overwrite the user config for the Plymouth drive decryption and boot sequence with the Leenium default and rebuild it.

sudo cp ~/.local/share/leenium/default/plymouth/* /usr/share/plymouth/themes/leenium/
sudo plymouth-set-default-theme leenium

if command -v limine-mkinitcpio &>/dev/null; then
  sudo limine-mkinitcpio
else
  sudo mkinitcpio -P
fi
