#!/bin/bash

# Install one of the approved terminals and set it as the default for Leenium (Super + Return etc).

if (($# == 0)); then
  echo "Usage: leenium-install-terminal [alacritty|ghostty|kitty]"
  exit 1
fi

package="$1"

# Map package name to desktop entry ID
case "$package" in
alacritty) desktop_id="Alacritty.desktop" ;;
ghostty) desktop_id="com.mitchellh.ghostty.desktop" ;;
kitty) desktop_id="kitty.desktop" ;;
*)
  echo "Unknown terminal: $package"
  exit 1
  ;;
esac

case "$desktop_id" in
kitty.desktop)
  fallback_ids=("Alacritty.desktop" "com.mitchellh.ghostty.desktop")
  ;;
Alacritty.desktop)
  fallback_ids=("kitty.desktop" "com.mitchellh.ghostty.desktop")
  ;;
com.mitchellh.ghostty.desktop)
  fallback_ids=("kitty.desktop" "Alacritty.desktop")
  ;;
esac

# Install package
if leenium-pkg-add $package; then
  # Copy custom desktop entry for alacritty with X-TerminalArg* keys
  if [[ $package == "alacritty" ]]; then
    mkdir -p ~/.local/share/applications
    cp $LEENIUM_PATH/applications/Alacritty.desktop ~/.local/share/applications/
  fi

  # Update xdg-terminals.list to prioritize the proper terminal
  cat >~/.config/xdg-terminals.list <<EOF
# Terminal emulator preference order for xdg-terminal-exec
# The first found and valid terminal will be used
$desktop_id
${fallback_ids[0]}
${fallback_ids[1]}
EOF
else
  echo "Failed to install $package"
fi
