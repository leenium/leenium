#!/bin/bash

if [[ -z $1 ]]; then
  echo "Usage: leenium-theme-set <theme-name>"
  exit 1
fi

CURRENT_THEME_PATH="$HOME/.config/leenium/current/theme"
NEXT_THEME_PATH="$HOME/.config/leenium/current/next-theme"
USER_THEMES_PATH="$HOME/.config/leenium/themes"
LEENIUM_THEMES_PATH="$LEENIUM_PATH/themes"

THEME_NAME=$(echo "$1" | sed -E 's/<[^>]+>//g' | tr '[:upper:]' '[:lower:]' | tr ' ' '-')

if [[ ! -d $LEENIUM_THEMES_PATH/$THEME_NAME ]] && [[ ! -d $USER_THEMES_PATH/$THEME_NAME ]]; then
  echo "Theme '$THEME_NAME' does not exist"
  exit 1
fi

# Setup clean next theme directory (for atomic theme config swapping)
rm -rf "$NEXT_THEME_PATH"
mkdir -p "$NEXT_THEME_PATH"

# Copy official theme first, then overlay user customizations on top
cp -r "$LEENIUM_THEMES_PATH/$THEME_NAME/"* "$NEXT_THEME_PATH/" 2>/dev/null
cp -r "$USER_THEMES_PATH/$THEME_NAME/"* "$NEXT_THEME_PATH/" 2>/dev/null

# Generate dynamic configs
leenium-theme-set-templates

# Swap next theme in as current
rm -rf "$CURRENT_THEME_PATH"
mv "$NEXT_THEME_PATH" "$CURRENT_THEME_PATH"

# Store theme name for reference
echo "$THEME_NAME" >"$HOME/.config/leenium/current/theme.name"

# Change background with theme
leenium-theme-bg-next

# Restart components to apply new theme
if pgrep -x waybar >/dev/null; then
  leenium-restart-waybar
fi
leenium-restart-swayosd
leenium-restart-terminal
leenium-restart-hyprctl
leenium-restart-btop
leenium-restart-opencode
leenium-restart-mako

# Change app-specific themes
leenium-theme-set-gnome
leenium-theme-set-browser
leenium-theme-set-vscode
leenium-theme-set-keyboard

# Call hook on theme set
leenium-hook theme-set "$THEME_NAME"
